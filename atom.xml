    <title>Cookie完整的公用封装方式</title>
    <link href="http://pokio.fun/posts/17334.html"/>
    <id>http://pokio.fun/posts/17334.html</id>
    <published>2018-08-20T07:22:42.000Z</published>
    <updated>2020-09-25T17:21:09.365Z</updated>
    
    <summary type="html">
    
      &lt;pre&gt;&lt;code class=&quot;javascript&quot;&gt;var Cookie-function = {
    setCookie: function(name, value) {
        //写cookies 
        var d = new Date();
        d.setTime(d.getTime() + (7 * 24s * 60 * 60 * 1000));
        var expires = &amp;quot;expires=&amp;quot; + d.toUTCString();
        document.cookie = name + &amp;quot;=&amp;quot; + value + &amp;quot;; &amp;quot; + expires;
    },
    getCookie: function(cname) {
        //读取cookies 
        var name = cname + &amp;quot;=&amp;quot;;
        var ca = document.cookie.split(&amp;#39;;&amp;#39;);
        for (var i = 0; i &amp;lt; ca.length; i++) {
             var c = ca[i];
             while (c.charAt(0) == &amp;#39; &amp;#39;) c = c.substring(1);
             if (c.indexOf(name) != -1) return c.substring(name.length, c.length);
         }
        return &amp;quot;&amp;quot;;
    },
    delCookie: function(name) {
         //删除cookies 
         f.setCookie(name, &amp;quot;&amp;quot;, -1);
    },
}
&lt;/code&gt;&lt;/pre&gt;
    
    </summary>
    
